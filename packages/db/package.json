    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prisma": "^6.8.2",
    "typescript": "^5.8.3"
  }
}
