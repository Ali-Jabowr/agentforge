# Neon (or any Postgres) connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local dev port only — Vercel ignores this
PORT=3001

# Clerk — from https://dashboard.clerk.com > API Keys
CLERK_SECRET_KEY=sk_test_...

# Clerk RSA public key for offline JWT verification (no network call per request)
# In Clerk dashboard: API Keys > Advanced > JWT public key
# Must be double-quoted in .env so dotenv parses the multi-line value correctly
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----
<paste key here>
-----END PUBLIC KEY-----"
